default_platform(:ios)

platform :ios do

  desc "Build the app and optionally upload to TestFlight"
  lane :build_and_upload do |options|
    deploy = options[:deploy_to_testflight] == "true"

    # Increment build number using timestamp
    build_number = Time.now.strftime("%Y%m%d%H%M")
    increment_build_number(
      build_number: build_number,
      xcodeproj: "App.xcodeproj"
    )

    if deploy
      # Build for App Store / TestFlight
      build_app(
        workspace: "App.xcworkspace",
        scheme: "App",
        configuration: "Release",
        export_method: "app-store",
        output_directory: "build",
        output_name: "FluentAI.ipa",
        export_options: {
          provisioningProfiles: {
            "com.fluentai.app" => "FluentAI AppStore"
          }
        }
      )

      # Upload to TestFlight
      api_key = app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
        key_content: Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_BASE64"] || ""),
        is_key_content_base64: false
      )

      upload_to_testflight(
        api_key: api_key,
        ipa: "build/FluentAI.ipa",
        skip_waiting_for_build_processing: true
      )

      UI.success("✅ Uploaded to TestFlight successfully!")
    else
      # Build Ad Hoc for testing (no signing required for CI check)
      build_app(
        workspace: "App.xcworkspace",
        scheme: "App",
        configuration: "Release",
        export_method: "ad-hoc",
        output_directory: "build",
        output_name: "FluentAI.ipa"
      )

      UI.success("✅ IPA built successfully!")
    end
  end

  desc "Run tests"
  lane :test do
    run_tests(
      workspace: "App.xcworkspace",
      scheme: "App",
      devices: ["iPhone 15"]
    )
  end

  error do |lane, exception|
    UI.error("❌ Lane #{lane} failed: #{exception.message}")
  end
end
